# Gemini API Key (Required for AI SEO Metadata and Nano Banana Thumbnails)
GEMINI_API_KEY=your_gemini_api_key

# Facebook Graph API (Required for Facebook Page & Instagram Reels Uploads)
FACEBOOK_PAGE_ACCESS_TOKEN=your_fb_page_access_token
FACEBOOK_PAGE_ID=your_fb_page_id
INSTAGRAM_ACCOUNT_ID=your_ig_account_id

# -------------------------------------------------------------
# YouTube Authentication Note:
# YouTube does NOT use this .env file. Instead, you MUST download 
# a "client_secrets.json" file from your Google Cloud Console 
# (with the YouTube Data API v3 enabled) and place it in the root folder.
# -------------------------------------------------------------
